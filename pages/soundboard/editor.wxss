/* 音效板编辑器 */

.page { background:var(--md1-bg); min-height:100vh; display:flex; flex-direction:column; overflow-x:hidden; }

.nav-bar { position:relative; z-index:60; background:var(--md1-surface); flex-shrink:0; box-shadow:var(--md1-shadow-appbar); }
.nav-row { position:relative; display:flex; align-items:center; justify-content:center; height:88rpx; padding:0 220rpx; box-sizing:border-box; }
.nav-back { width:72rpx; height:72rpx; display:flex; align-items:center; justify-content:center; border-radius:50%; flex-shrink:0; }
.nav-back:active { background:rgba(255,255,255,0.08); }
.nav-back .material-icons { font-size:44rpx; color:var(--md1-text-primary); }
.nav-title { position:absolute; left:220rpx; right:220rpx; top:0; height:88rpx; display:flex; align-items:center; justify-content:center; text-align:center; font-size:36rpx; font-weight:600; color:var(--md1-text-primary); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; pointer-events:none; }
.nav-actions { position:absolute; left:20rpx; top:8rpx; height:72rpx; display:flex; align-items:center; gap:4rpx; z-index:2; }

.editor-scroll { flex:1; min-height:0; width:100%; padding:16rpx 20rpx; box-sizing:border-box; }

.editor-card {
  background:var(--md1-surface-raised); border-radius:var(--md1-radius);
  padding:24rpx; margin-bottom:24rpx;
  width:100%; max-width:100%; box-sizing:border-box;
  box-shadow:var(--md1-shadow-card);
}

.ec-title { font-size:28rpx; font-weight:600; color:var(--md1-primary); }
.ec-row-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:12rpx; }

.ec-row {
  display:flex; align-items:center; justify-content:space-between;
  padding:10rpx 0; border-bottom:1px solid var(--md1-divider);
}
.ec-row:last-child { border-bottom:none; }
.ec-row-label { font-size:28rpx; color:var(--md1-text-primary); }
.ec-hint { font-size:22rpx; color:var(--md1-text-hint); padding:8rpx 0 12rpx; line-height:1.6; }

.ec-field { margin:12rpx 0; }
.ec-field label { display:block; font-size:22rpx; color:var(--md1-text-secondary); margin-bottom:8rpx; }

.ec-btn-row { display:flex; gap:8rpx; padding-top:8rpx; }
.icon-btn-sm.disabled { opacity:0.3; pointer-events:none; }

.group-chips { white-space:nowrap; height:112rpx; display:flex; margin:10rpx 0; }
.group-chip {
  display:inline-flex; align-items:center; gap:12rpx;
  background:rgba(255,255,255,0.12); height:96rpx; padding:0 20rpx;
  border-radius:var(--md1-radius); color:var(--md1-text-secondary);
  font-size:30rpx; white-space:nowrap; margin-right:4rpx; flex-shrink:0;
}
.group-chip.active { background:rgba(3,131,135,0.18); }
.chip-count { font-size:18rpx; opacity:0.5; }

.group-detail { margin-top:10rpx; padding-top:10rpx; border-top:1px solid var(--md1-divider); }

.icon-row { display:flex; align-items:center; gap:16rpx; padding:8rpx 0; }
.cur-icon {
  width:72rpx; height:72rpx; border-radius:var(--md1-radius); background:var(--md1-field);
  color:var(--md1-text-primary); display:flex; align-items:center; justify-content:center;
}
.arrow { font-size:36rpx; color:var(--md1-text-hint); }

.batch-actions { display:flex; align-items:center; justify-content:flex-end; gap:4rpx; flex-wrap:wrap; }

.item-row {
  display:flex; align-items:center; gap:8rpx;
  padding:16rpx; margin:2rpx 0;
  min-height:144rpx; width:100%; box-sizing:border-box;
  border-radius:var(--md1-radius); background:var(--md1-surface-raised);
  box-shadow:none;
  transition:background-color 0.16s cubic-bezier(0.4,0,0.2,1), box-shadow 0.16s cubic-bezier(0.4,0,0.2,1), transform 0.16s cubic-bezier(0.4,0,0.2,1);
}
.item-row:active { background:var(--md1-surface-menu); }
.item-row.selected { background:rgba(3,131,135,0.14); }
.item-row.dragging { box-shadow:var(--md1-shadow-drag); transform:scale(1.01); }
.item-check { width:56rpx; height:56rpx; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.native-checkbox {
  width:40rpx; height:40rpx; border-radius:4rpx;
  border:4rpx solid var(--md1-text-secondary);
  box-sizing:border-box; display:flex; align-items:center; justify-content:center;
  background:transparent; color:#fff;
  transition:background-color 0.12s cubic-bezier(0.4,0,0.2,1), border-color 0.12s cubic-bezier(0.4,0,0.2,1);
}
.native-checkbox.checked { background:var(--md1-primary); border-color:var(--md1-primary); }
.native-checkbox-mark { font-size:30rpx; line-height:1; font-weight:700; color:#fff; }
.item-body { flex:1; min-width:0; }
.item-name { font-size:26rpx; color:var(--md1-text-primary); font-weight:500; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.item-sub { font-size:22rpx; color:var(--md1-text-hint); margin-top:2rpx; overflow:hidden; text-overflow:ellipsis; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; }
.item-actions { display:flex; gap:4rpx; flex-shrink:0; }
.btn-micro {
  width:58rpx; height:58rpx; display:flex; align-items:center; justify-content:center;
  font-size:40rpx; color:var(--md1-text-secondary); border-radius:50%;
}
.btn-micro .material-icons { font-size:46rpx; color:currentColor; }
.btn-micro:active { background:rgba(255,255,255,0.08); }
.drag-handle { color:var(--md1-text-primary); }

.dialog-title { font-size:32rpx; font-weight:500; color:var(--md1-text-primary); margin-bottom:20rpx; }

.picker-panel {
  background:var(--md1-surface-menu); border-radius:var(--md1-radius) var(--md1-radius) 0 0;
  width:100%; max-height:60vh; display:flex; flex-direction:column; box-sizing:border-box;
}
.picker-header { padding:28rpx 32rpx; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(--md1-divider); }
.picker-title { font-size:32rpx; font-weight:500; color:var(--md1-text-primary); }
.icon-grid { display:flex; flex-wrap:wrap; gap:8rpx; padding:24rpx; box-sizing:border-box; }
.icon-cell {
  width:72rpx; height:72rpx; border-radius:var(--md1-radius);
  display:flex; align-items:center; justify-content:center;
  background:var(--md1-field); color:var(--md1-text-primary);
}
.icon-cell.active { background:rgba(3,131,135,0.18); color:var(--md1-primary); }
.icon-cell .material-icons { font-size:48rpx; color:currentColor; }
