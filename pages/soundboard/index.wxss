/* 音效板 */
.page { display:flex; flex-direction:column; height:100vh; background:var(--md1-bg); }

.nav-bar { position:relative; z-index:60; background:var(--md1-surface); flex-shrink:0; box-shadow:var(--md1-shadow-appbar); }
.nav-row { position:relative; display:flex; align-items:center; justify-content:center; height:88rpx; padding:0 220rpx; box-sizing:border-box; }
.nav-title { position:absolute; left:220rpx; right:220rpx; top:0; height:88rpx; display:flex; align-items:center; justify-content:center; text-align:center; font-size:36rpx; font-weight:600; color:var(--md1-text-primary); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; pointer-events:none; }
.nav-actions { position:absolute; left:20rpx; top:8rpx; height:72rpx; display:flex; align-items:center; gap:4rpx; z-index:2; }
.nav-menu { margin-right:0; }

.group-tabs-card { height:96rpx; margin:8rpx 32rpx 20rpx; display:flex; flex-shrink:0; overflow:hidden; background:var(--md1-surface-raised); border-radius:var(--md1-radius); box-shadow:var(--md1-shadow-card); }
.page.nav-bottom .group-tabs-card { margin-bottom:calc(128rpx + env(safe-area-inset-bottom)); }
.chip-scroll { flex:1; min-width:0; display:flex; white-space:nowrap; height:96rpx; }
.group-chip { display:inline-flex; align-items:center; gap:12rpx; background:transparent; height:96rpx; padding:0 20rpx; border-radius:var(--md1-radius-sm); color:var(--md1-text-secondary); font-size:30rpx; white-space:nowrap; margin-right:4rpx; flex-shrink:0; }
.group-chip.active { background:rgba(3,131,135,0.16); color:var(--md1-primary); }
.group-edit-segment { width:104rpx; height:96rpx; background:var(--md1-primary); color:#fff; display:flex; align-items:center; justify-content:center; flex-shrink:0; }

.sound-list { flex:1; width:100%; box-sizing:border-box; }
.sound-list-inner { width:100%; box-sizing:border-box; padding-top:16rpx; }
.sound-list-inner.grid { display:flex; flex-wrap:wrap; padding:16rpx 28rpx 0; box-sizing:border-box; }
.grid-cell { padding:4rpx; box-sizing:border-box; }

/* ===== LIST ITEM ===== Match Android SoundboardListItem exactly */
.sound-card { background:var(--md1-surface-raised); border-radius:var(--md1-radius-sm); box-shadow:var(--md1-shadow-card); }
.sound-card.playing { background:rgba(3,131,135,0.1); border:1px solid rgba(3,131,135,0.25); box-sizing:border-box; }

.slist { margin:0 32rpx 8rpx; padding:20rpx 24rpx; box-sizing:border-box; }
.slist-row { display:flex; align-items:center; gap:12rpx; }
.slist-info { flex:1; min-width:0; }
.slist-name { font-size:28rpx; color:var(--md1-text-primary); font-weight:500; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.slist-word { font-size:24rpx; color:var(--md1-text-secondary); margin-top:4rpx; }
.slist-play { width:96rpx; height:96rpx; border-radius:50%; background:transparent; color:var(--md1-text-primary); display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:48rpx; }
.slist-play.stop { background:transparent; color:var(--md1-error); }
.slist-play:active { background:transparent; }
.slist-progress { height:6rpx; background:rgba(255,255,255,0.06); border-radius:3rpx; margin-top:12rpx; }
.slist-progress-fill { height:100%; background:var(--md1-primary); width:0%; border-radius:3rpx; animation:none; }
.slist-progress-fill.running { animation:progressAnim 8s linear forwards; }
.slist-empty { text-align:center; color:var(--md1-text-hint); padding:40rpx; }

/* ===== GRID ITEM ===== Match Android SoundboardGridItem exactly */
.sgrid { height:236rpx; padding:20rpx; display:flex; flex-direction:column; }
.sgrid-top { display:flex; justify-content:space-between; align-items:flex-start; }
.sgrid-info { flex:1; min-width:0; }
.sgrid-name { font-size:28rpx; color:var(--md1-text-primary); font-weight:500; overflow:hidden; text-overflow:ellipsis; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; }
.sgrid-word { font-size:24rpx; color:var(--md1-text-secondary); margin-top:4rpx; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.sgrid-play { width:96rpx; height:96rpx; border-radius:50%; background:transparent; color:var(--md1-text-primary); display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:48rpx; }
.sgrid-play.stop { background:transparent; color:var(--md1-error); }
.sgrid-play:active { background:transparent; }
.sgrid-spacer { flex:1; }
.sgrid-progress { height:6rpx; background:rgba(255,255,255,0.06); border-radius:3rpx; }
.sgrid-progress-fill { height:100%; background:var(--md1-primary); width:0%; border-radius:3rpx; animation:none; }
.sgrid-progress-fill.running { animation:progressAnim 8s linear forwards; }

@keyframes progressAnim { from { width:0%; } to { width:100%; } }

/* ---- inline sheets ---- */
.icon-picker { white-space:nowrap; height:80rpx; display:flex; }
.icon-chip { display:inline-flex; align-items:center; justify-content:center; width:56rpx; height:56rpx; border-radius:50%; margin-right:8rpx; color:var(--md1-text-primary); flex-shrink:0; }
.icon-chip.active { background:rgba(3,131,135,0.18); color:var(--md1-primary); }
.sheet-editor-field { margin-bottom:24rpx; }
.sheet-editor-field label { display:block; font-size:22rpx; color:var(--md1-text-secondary); margin-bottom:8rpx; }
