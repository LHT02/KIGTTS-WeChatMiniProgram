<import src="../../templates/shell.wxml" />

<view class="page {{themeClass}} nav-{{navMode}}">
  <view class="nav-bar" style="padding-top:{{statusBarH}}px;">
    <view class="nav-row">
      <view class="nav-actions">
        <view class="icon-btn-sm nav-menu" wx:if="{{navMode === 'drawer'}}" bindtap="onOpenDrawer">
          <text class="material-icons">menu</text>
        </view>
        <view class="icon-btn-sm" bindtap="onToggleLayout">
          <text class="material-icons">{{config.layoutMode === 'grid' ? 'view_list' : 'grid_view'}}</text>
        </view>
      </view>
      <view class="nav-title">音效板</view>
    </view>
  </view>
  <scroll-view class="sound-list" scroll-y="true" enable-flex>
    <view class="sound-list-inner {{layoutCols > 1 ? 'grid' : ''}}">
    <block wx:for="{{currentGroup.items}}" wx:key="id" wx:for-item="item" wx:for-index="idx">
      <!-- List mode -->
      <view class="sound-card slist {{playingId === item.id ? 'playing' : ''}}" wx:if="{{layoutCols === 1}}"
            data-item="{{item}}" data-index="{{idx}}" bindtap="onTogglePlayback">
        <view class="slist-row">
          <view class="slist-info">
            <view class="slist-name">{{item.title || '未命名音效'}}</view>
            <view class="slist-word" wx:if="{{item.wakeWord}}">{{item.wakeWord}}</view>
          </view>
          <view class="slist-play {{playingId === item.id ? 'stop' : ''}}">
            <text class="material-icons">{{playingId === item.id ? 'stop' : 'play_arrow'}}</text>
          </view>
        </view>
        <view class="slist-progress"><view class="slist-progress-fill {{playingId === item.id ? 'running' : ''}}"></view></view>
      </view>

      <!-- Grid mode -->
      <view class="grid-cell" wx:if="{{layoutCols > 1}}" style="width: {{100 / layoutCols}}%;">
        <view class="sound-card sgrid {{playingId === item.id ? 'playing' : ''}}"
              data-item="{{item}}" data-index="{{idx}}" bindtap="onTogglePlayback">
          <view class="sgrid-top">
            <view class="sgrid-info">
              <view class="sgrid-name">{{item.title || '未命名音效'}}</view>
              <view class="sgrid-word" wx:if="{{item.wakeWord}}">{{item.wakeWord}}</view>
            </view>
            <view class="sgrid-play {{playingId === item.id ? 'stop' : ''}}">
              <text class="material-icons">{{playingId === item.id ? 'stop' : 'play_arrow'}}</text>
            </view>
          </view>
          <view class="sgrid-spacer"></view>
          <view class="sgrid-progress"><view class="sgrid-progress-fill {{playingId === item.id ? 'running' : ''}}"></view></view>
        </view>
      </view>
    </block>

    <view class="sound-card slist" wx:if="{{layoutCols === 1 && currentGroup.items.length === 0}}" bindtap="onAddItem">
      <view class="slist-empty">当前分组暂无音效，请进入编辑页添加</view>
    </view>
    </view>
  </scroll-view>

  <view class="group-tabs-card">
    <scroll-view class="chip-scroll" scroll-x="true" enable-flex>
      <view class="group-chip {{config.selectedGroupId === item.id ? 'active' : ''}}"
            wx:for="{{config.groups}}" wx:key="id" data-gid="{{item.id}}" bindtap="onGroupTap">
        <text class="material-icons" style="font-size:40rpx;">{{item.icon || 'music_note'}}</text>
        <text>{{item.title}}</text>
      </view>
    </scroll-view>
    <view class="group-edit-segment" bindtap="onOpenEditor">
      <text class="material-icons" style="font-size:44rpx; color:#fff;">edit</text>
    </view>
  </view>

</view>

<view class="sheet-mask {{themeClass}}" wx:if="{{showEditor}}" bindtap="onCloseEditor">
  <view class="sheet-panel" catchtap="noop">
    <view class="sheet-header">
      <text class="sheet-title">{{editingItem ? '编辑音效' : '添加音效'}}</text>
      <text class="material-icons lg" bindtap="onCloseEditor" style="padding:8rpx;">close</text>
    </view>
    <view class="sheet-body">
      <view class="sheet-editor-field">
        <label>音效名称</label>
        <view class="md-text-field"><input value="{{editingTitle}}" bindinput="onEditorTitleChange" placeholder="音效名称" /></view>
      </view>
      <view class="sheet-editor-field">
        <label>标签（可选）</label>
        <view class="md-text-field"><input value="{{editingWakeWord}}" bindinput="onEditorWakeWordChange" placeholder="标签" /></view>
      </view>
      <view class="sheet-editor-field">
        <label>音频文件</label>
        <view class="flex-row" style="gap:12rpx;">
          <text class="flex-1 text-ellipsis" style="color:var(--md1-text-hint);">{{editingFilePath || '未选择'}}</text>
          <view class="btn-outlined-sm" bindtap="onChooseAudioFile">选择</view>
        </view>
      </view>
    </view>
    <view class="sheet-footer">
      <view class="btn-text-sm" bindtap="onCloseEditor">取消</view>
      <view class="btn-filled-sm" bindtap="onSaveItem">保存</view>
    </view>
  </view>
</view>

<template is="appDrawer" data="{{drawerOpen: drawerOpen, navItems: navItems, currentPath: currentPath, themeClass: themeClass, logoGlyph: logoGlyph, statusBarH: statusBarH}}" />

<view class="sheet-mask {{themeClass}}" wx:if="{{showGroupEditor}}" bindtap="onCloseGroupEditor">
  <view class="sheet-panel" catchtap="noop">
    <view class="sheet-header">
      <text class="sheet-title">{{editingGroup ? '编辑分组' : '添加分组'}}</text>
      <text class="material-icons lg" bindtap="onCloseGroupEditor" style="padding:8rpx;">close</text>
    </view>
    <view class="sheet-body">
      <view class="sheet-editor-field">
        <label>分组名称</label>
        <view class="md-text-field"><input value="{{editingGroupTitle}}" bindinput="onEditorGroupTitleChange" placeholder="分组名称" /></view>
      </view>
      <view class="sheet-editor-field">
        <label>图标</label>
        <scroll-view class="icon-picker" scroll-x="true">
          <view class="icon-chip {{item === editingGroupIcon ? 'active' : ''}}" wx:for="{{groupIcons}}" wx:key="*this"
                data-icon="{{item}}" bindtap="onPickGroupIcon">
            <text class="material-icons sm">{{item}}</text>
          </view>
        </scroll-view>
      </view>
    </view>
    <view class="sheet-footer">
      <view class="btn-text-sm" bindtap="onCloseGroupEditor">取消</view>
      <view class="btn-filled-sm" bindtap="onSaveGroup">保存</view>
    </view>
  </view>
</view>
