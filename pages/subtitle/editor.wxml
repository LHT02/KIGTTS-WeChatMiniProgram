<view class="page route-push {{themeClass}}"
      bindtouchmove="onRippleTouchMove" bindtouchend="onRippleTouchEnd" bindtouchcancel="onRippleTouchCancel">
  <view class="nav-bar" style="padding-top:{{statusBarH}}px;">
    <view class="nav-row">
      <view class="nav-actions">
        <view class="nav-back" data-ripple="1" bindtouchstart="onRippleTouchStart" bindtap="onNavBack">
          <text class="material-icons">arrow_back</text>
        </view>
      </view>
      <view class="nav-title">编辑</view>
    </view>
  </view>
  <view class="editor-content">
  <view class="card">
    <view class="section-title">分组信息</view>
    <view class="form-field">
      <label>名称</label>
      <view class="md-text-field">
        <input value="{{title}}" bindinput="onTitleInput" placeholder="分组名称" placeholder-class="input-placeholder" />
      </view>
    </view>
    <view class="form-field">
      <label>图标</label>
      <view class="icon-row" data-ripple="1" bindtouchstart="onRippleTouchStart" bindtap="onOpenIconPicker">
        <view class="cur-icon">
          <text class="material-icons" style="font-size:44rpx;">{{icon}}</text>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>
    <view class="flex-row" style="justify-content:flex-end; margin-top:16rpx;">
      <view class="btn-filled-sm" data-ripple="1" data-ripple-color="rgb(255,255,255)" bindtouchstart="onRippleTouchStart" bindtap="onSaveGroup">保存分组</view>
    </view>
  </view>

  <view class="card">
    <view class="section-header">
      <view class="section-title">快捷文本</view>
      <view wx:if="{{!batchMode}}" class="btn-text-sm" data-ripple="1" bindtouchstart="onRippleTouchStart" bindtap="onAddItem">＋ 新增</view>
      <view wx:else class="batch-actions">
        <view class="btn-text-sm" wx:if="{{batchCount > 0 && configGroups.length > 1 && groupId}}" data-ripple="1" bindtouchstart="onRippleTouchStart" bindtap="onBatchMove">移动到</view>
        <view class="btn-text-sm" wx:if="{{batchCount > 0}}" data-ripple="1" bindtouchstart="onRippleTouchStart" bindtap="onBatchDelete">删除所选</view>
        <view class="btn-text-sm danger" data-ripple="1" bindtouchstart="onRippleTouchStart" bindtap="onExitBatch">关闭</view>
      </view>
    </view>
    <view class="item-row {{batchMode ? 'batch-row' : ''}} {{selectedItems[idx] ? 'selected' : ''}} {{draggingIndex === idx ? 'dragging' : ''}}"
          wx:for="{{items}}" wx:key="id" wx:for-index="idx"
          data-index="{{idx}}" data-ripple="1" data-ripple-size="72" bindtouchstart="onRippleTouchStart" bindtap="onItemRowTap" bindlongpress="onItemLongPress">
      <view wx:if="{{batchMode}}" class="item-check" data-index="{{idx}}" hover-class="pressed" hover-start-time="0" hover-stay-time="300" catchtap="onToggleBatchItem">
        <view class="native-checkbox {{selectedItems[idx] ? 'checked' : ''}}">
          <view class="native-checkbox-ripple"></view>
          <view class="native-checkbox-bg"></view>
          <text wx:if="{{selectedItems[idx]}}" class="native-checkbox-mark material-icons">check</text>
        </view>
      </view>
      <view class="item-content">
        <text>{{item.text}}</text>
      </view>
      <view class="item-actions" wx:if="{{!batchMode}}" catchlongpress="noop">
        <view class="btn-micro" data-index="{{idx}}" data-ripple="1" catchtouchstart="onRippleTouchStart" catchtap="onItemTap">
          <text class="material-icons">edit</text>
        </view>
        <view class="btn-micro drag-handle" data-index="{{idx}}" catchtouchstart="onItemDragStart" catchtouchmove="onItemDragMove" catchtouchend="onItemDragEnd" catchtouchcancel="onItemDragEnd" catchlongpress="noop">
          <text class="material-icons">drag_indicator</text>
        </view>
        <view class="btn-micro {{items.length <= 1 ? 'disabled' : ''}}" data-index="{{idx}}" data-ripple="1" catchtouchstart="onRippleTouchStart" catchtap="onDeleteItem" style="color:var(--md1-error);">
          <text class="material-icons">delete</text>
        </view>
      </view>
    </view>
    <view class="empty-state compact" wx:if="{{items.length === 0}}">暂无快捷文本</view>
  </view>
  </view>
</view>

<view class="sheet-mask {{themeClass}}" wx:if="{{showIconPicker}}" bindtap="onCloseIconPicker"
      bindtouchmove="onRippleTouchMove" bindtouchend="onRippleTouchEnd" bindtouchcancel="onRippleTouchCancel">
  <view class="picker-panel" catchtap="noop">
    <view class="picker-header">
      <text class="picker-title">选择图标</text>
      <text class="material-icons" bindtap="onCloseIconPicker" style="padding:8rpx;">close</text>
    </view>
    <view class="icon-grid">
      <view class="icon-cell {{item === icon ? 'active' : ''}}" wx:for="{{iconList}}" wx:key="*this"
            data-icon="{{item}}" data-ripple="1" bindtouchstart="onRippleTouchStart" bindtap="onPickIcon">
        <text class="material-icons">{{item}}</text>
      </view>
    </view>
  </view>
</view>

<view class="sheet-mask {{themeClass}}" wx:if="{{showItemEditor}}" bindtap="onCloseItemEditor"
      bindtouchmove="onRippleTouchMove" bindtouchend="onRippleTouchEnd" bindtouchcancel="onRippleTouchCancel">
  <view class="sheet-panel" catchtap="noop">
    <view class="sheet-header">
      <text class="sheet-title">{{editingIndex >= 0 ? '编辑' : '添加'}}快捷文本</text>
      <text class="material-icons lg" bindtap="onCloseItemEditor" style="padding:8rpx;">close</text>
    </view>
    <view class="sheet-body">
      <view class="form-field">
        <label>文本内容</label>
        <view class="md-text-field"><input value="{{editingText}}" bindinput="onItemTextInput" placeholder="文本内容" placeholder-class="input-placeholder" /></view>
      </view>
    </view>
    <view class="sheet-footer">
      <view class="btn-text-sm" data-ripple="1" bindtouchstart="onRippleTouchStart" bindtap="onCloseItemEditor">取消</view>
      <view class="btn-filled-sm" data-ripple="1" data-ripple-color="rgb(255,255,255)" bindtouchstart="onRippleTouchStart" bindtap="onSaveItem">保存</view>
    </view>
  </view>
</view>

<view class="ripple-host" wx:if="{{rippleList.length}}">
  <view class="sc-ripple-clip" wx:for="{{rippleList}}" wx:key="id" style="{{item.clipStyle}}">
    <view class="sc-ripple" data-id="{{item.id}}" style="{{item.style}}" bindanimationend="onRippleAnimationEnd"></view>
  </view>
</view>
