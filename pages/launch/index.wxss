.launch-page {
  min-height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  background:#000;
  padding:0;
  box-sizing:border-box;
  overflow:hidden;
  transition:opacity 0.16s cubic-bezier(0.4,0,0.2,1);
}

.launch-page.theme-light { background:#fff; }
.launch-page.leaving { opacity:0; }

.launch-brand {
  width:100%;
  display:flex;
  align-items:center;
  justify-content:center;
  animation:launchLogoIn 0.18s cubic-bezier(0.4,0,0.2,1);
}

.launch-logo {
  width:430rpx;
  height:108rpx;
  max-width:88vw;
}

@keyframes launchLogoIn {
  from { opacity:0; transform:scale(0.98); }
  to { opacity:1; transform:scale(1); }
}
