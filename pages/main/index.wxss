@import "../../templates/shell.wxss";

.main-page {
  background: var(--md1-bg);
  height: 100vh;
  min-height: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.main-nav {
  position: relative;
  z-index: 900;
  background: var(--md1-surface);
  flex-shrink: 0;
  box-shadow: var(--md1-shadow-appbar);
}

.main-nav-row {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 220rpx;
  box-sizing: border-box;
  transition: opacity 140ms cubic-bezier(0.4,0,0.2,1);
}

.nav-title {
  position: absolute;
  left: 220rpx;
  right: 220rpx;
  top: 0;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--md1-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  pointer-events: none;
}

.nav-actions {
  position: absolute;
  left: 20rpx;
  top: 8rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
  z-index: 2;
}

.main-nav-row.chrome-changing {
  animation: chromeContentFade 160ms cubic-bezier(0.4,0,0.2,1);
}

@keyframes chromeContentFade {
  0% { opacity: 0; }
  100% { opacity: 1; }
}

.main-content {
  position: relative;
  flex: 1;
  min-height: 0;
  overflow: hidden;
  background: var(--md1-bg);
}

.main-panel {
  position: absolute;
  inset: 0;
  opacity: 0;
  transform: translateY(18rpx);
  pointer-events: none;
  transition: opacity 180ms cubic-bezier(0.2,0,0,1), transform 180ms cubic-bezier(0.2,0,0,1);
  will-change: opacity, transform;
}

.main-panel.active {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
  z-index: 1;
}

.main-tab-shell {
  flex-shrink: 0;
  z-index: 700;
  pointer-events: none;
  font-family: -apple-system-font, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
}

.tabbar {
  position: relative;
  min-height: 112rpx;
  padding: 6rpx 0 calc(6rpx + env(safe-area-inset-bottom));
  background: var(--md1-surface-raised);
  border-top: 1px solid var(--md1-divider);
  box-shadow: var(--md1-shadow-bottombar);
  display: block;
  box-sizing: border-box;
  pointer-events: auto;
  overflow: hidden;
}

.main-tab-shell.subtitle-current .tabbar {
  box-shadow: none;
}

.layout-row {
  display: flex;
  flex-direction: row;
}

.layout-start-center {
  justify-content: flex-start;
  align-items: center;
}

.main-tab-scroll {
  width: 100%;
  height: 100rpx;
}

.main-tab {
  min-width: 100%;
}

.tab-bar {
  position: relative;
  flex: 1 1 auto;
  min-width: 100%;
}

.tab-bar-list {
  flex: 1 1 auto;
  height: 96rpx;
  background: transparent;
  font-size: 30rpx;
  overflow-x: scroll;
}

.tab-bar-item {
  position: relative;
  z-index: 1;
  flex: 1 0 20%;
  flex-grow: 1;
  min-width: 0;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  color: var(--md1-text-secondary);
  -webkit-tap-highlight-color: transparent;
  transition: color 180ms cubic-bezier(0.4,0,0.2,1);
}

.sc-tab-btn {
  height: 96rpx;
  min-width: 88rpx;
  padding: 0 8rpx;
  border-radius: 2px;
  background-color: transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  box-sizing: border-box;
}

.tab-bar-item.active,
.tab-bar-item.active .tab-icon,
.tab-bar-item.active .tab-label {
  color: var(--md1-primary);
}

.tab-bar-item:active,
.sc-tab-btn:active {
  background: transparent;
}

.tab-icon {
  font-size: 44rpx;
  line-height: 1;
  transition: color 160ms cubic-bezier(0.4,0,0.2,1);
}

.tab-label {
  font-family: -apple-system-font, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 24rpx;
  line-height: 1.2;
  white-space: nowrap;
  transition: color 160ms cubic-bezier(0.4,0,0.2,1);
}

.tab-bar-driver {
  height: 4rpx;
  background: var(--md1-primary);
  pointer-events: none;
  transform-origin: 0 0;
}

.tab-bar-driver-transition {
  transition: transform 220ms cubic-bezier(0.4,0,0.2,1);
}

.tab-bar-driver-trans-transition {
  transition: width 220ms cubic-bezier(0.4,0,0.2,1), transform 220ms cubic-bezier(0.4,0,0.2,1);
  will-change: width;
}

.keyboard-hidden .main-content {
  flex-basis: 100vh;
}
