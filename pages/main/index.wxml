<import src="../../templates/shell.wxml" />

<view class="page main-page {{themeClass}} nav-{{navMode}} {{keyboardHidden ? 'keyboard-hidden' : ''}} {{shellOverlayOpen ? 'shell-overlay-open' : ''}}"
      style="--status-bar-h:{{statusBarH}}px;"
      bindtouchmove="onRippleTouchMove" bindtouchend="onRippleTouchEnd" bindtouchcancel="onRippleTouchCancel">
  <view class="nav-bar main-nav" style="padding-top:{{statusBarH}}px;" wx:if="{{!keyboardHidden}}">
    <view class="nav-row main-nav-row {{chromeAnimClass}}">
      <view class="nav-actions">
        <view class="icon-btn-sm nav-menu" wx:if="{{navMode === 'drawer'}}" data-ripple="1"
              capture-bind:tap="onRippleTap" capture-bind:longpress="onRippleLongPress" bindtap="onOpenDrawer">
          <text class="material-icons">menu</text>
        </view>
        <view class="icon-btn-sm" wx:for="{{activeActions}}" wx:key="action"
              data-action="{{item.action}}" data-ripple="1"
              capture-bind:tap="onRippleTap" capture-bind:longpress="onRippleLongPress" bindtap="onTopActionTap">
          <text class="material-icons">{{item.icon}}</text>
        </view>
      </view>
      <view class="nav-title">{{activeTitle}}</view>
    </view>
  </view>

  <view class="main-content">
    <view class="main-panel {{activePath === 'pages/subtitle/index' ? 'active' : ''}}">
      <tab-subtitle id="tab-subtitle" active="{{activePath === 'pages/subtitle/index'}}"
                    bindopendrawer="onOpenDrawer" bindkeyboardhidden="onKeyboardHidden" bindshellchange="onShellChange" bindshelloverlay="onShellOverlay" />
    </view>
    <view class="main-panel {{activePath === 'pages/card/index' ? 'active' : ''}}">
      <tab-card id="tab-card" active="{{activePath === 'pages/card/index'}}"
                bindopendrawer="onOpenDrawer" bindshellchange="onShellChange" />
    </view>
    <view class="main-panel {{activePath === 'pages/settings/drawing' ? 'active' : ''}}">
      <tab-drawing id="tab-drawing" active="{{activePath === 'pages/settings/drawing'}}"
                   bindopendrawer="onOpenDrawer" bindshellchange="onShellChange" />
    </view>
    <view class="main-panel {{activePath === 'pages/soundboard/index' ? 'active' : ''}}">
      <tab-soundboard id="tab-soundboard" active="{{activePath === 'pages/soundboard/index'}}"
                      bindopendrawer="onOpenDrawer" bindshellchange="onShellChange" />
    </view>
    <view class="main-panel {{activePath === 'pages/settings/index' ? 'active' : ''}}">
      <tab-settings id="tab-settings" active="{{activePath === 'pages/settings/index'}}"
                    bindopendrawer="onOpenDrawer" bindshellchange="onShellChange" />
    </view>
  </view>

  <view class="main-tab-shell {{activePath === 'pages/subtitle/index' ? 'subtitle-current' : ''}}" wx:if="{{navMode !== 'drawer' && !keyboardHidden}}">
    <view class="tabbar">
      <scroll-view class="main-tab-scroll" scroll-x="true" scroll-with-animation="true"
                   scroll-left="{{tabScrollLeft}}" enhanced="true" show-scrollbar="false"
                   bindscroll="onTabScroll">
        <view id="main-tab" class="layout-row layout-start-center main-tab">
          <view class="tab-bar">
            <view class="tab-bar-list layout-row layout-start-center">
              <view class="main-tab-item tab-bar-item {{activeIndex === index ? 'active' : ''}}"
                    wx:for="{{navItems}}" wx:key="path"
                    data-idx="{{index}}" data-path="{{item.path}}" data-ripple="1"
                    capture-bind:tap="onRippleTap" capture-bind:longpress="onRippleLongPress" bindtap="onTabTap">
                <view class="sc-tab-btn">
                  <text class="material-icons tab-icon">{{item.icon}}</text>
                  <text class="tab-label">{{item.text}}</text>
                </view>
              </view>
            </view>
            <view class="tab-bar-driver tab-bar-driver-transition {{tabDriverUnequal ? 'tab-bar-driver-trans-transition' : ''}}"
                  style="{{tabDriverStyle}}"></view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>

<template is="appDrawer" data="{{drawerOpen: drawerOpen, navItems: navItems, currentPath: activePath, themeClass: themeClass, logoGlyph: logoGlyph, statusBarH: statusBarH}}" />

<view class="ripple-host">
  <view class="sc-ripple-clip" wx:for="{{rippleList}}" wx:key="id" style="{{item.clipStyle}}">
    <view class="sc-ripple {{item.hold ? 'sc-ripple-hold' : ''}}" data-id="{{item.id}}" style="{{item.style}}" bindanimationend="onRippleAnimationEnd"></view>
  </view>
</view>
