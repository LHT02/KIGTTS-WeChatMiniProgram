/* 设置页 */
.page { background:var(--md1-bg); height:100vh; display:flex; flex-direction:column; overflow:hidden; }
.nav-bar { position:relative; z-index:60; background:var(--md1-surface); flex-shrink:0; box-shadow:var(--md1-shadow-appbar); }
.nav-row { position:relative; display:flex; align-items:center; justify-content:center; height:88rpx; padding:0 220rpx; box-sizing:border-box; }
.nav-title { position:absolute; left:220rpx; right:220rpx; top:0; height:88rpx; display:flex; align-items:center; justify-content:center; text-align:center; font-size:36rpx; font-weight:600; color:var(--md1-text-primary); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; pointer-events:none; }
.nav-actions { position:absolute; left:20rpx; top:8rpx; height:72rpx; display:flex; align-items:center; gap:4rpx; z-index:2; }
.nav-menu { margin-right:0; }
.settings-scroll { flex:1; min-height:0; height:0; width:100%; box-sizing:border-box; }
.settings-scroll-inner { padding:0 32rpx 40rpx; box-sizing:border-box; }
.page.nav-bottom .settings-scroll-inner { padding-bottom:calc(128rpx + env(safe-area-inset-bottom)); }
.settings-bottom-spacer { height:1rpx; padding-bottom:env(safe-area-inset-bottom); box-sizing:content-box; }

.about-card {
  background:var(--md1-surface-raised); border-radius:var(--md1-radius);
  padding:32rpx 24rpx 30rpx; margin-top:16rpx; margin-bottom:16rpx;
  width:100%; box-sizing:border-box;
  display:flex; flex-direction:column; align-items:center; gap:20rpx;
  box-shadow:var(--md1-shadow-card);
}
.about-logo-img { display:block; width:420rpx; height:106rpx; max-width:88%; flex-shrink:0; }
.about-version { font-size:26rpx; color:var(--md1-text-hint); margin-top:-10rpx; }
.about-desc { font-size:24rpx; color:var(--md1-text-secondary); line-height:1.6; text-align:center; }
.about-links { font-size:24rpx; color:var(--md1-text-hint); }
.about-link { color:var(--md1-primary); }
.about-divider { color:var(--md1-text-disabled); margin:0 6rpx; }

.settings-card {
  background:var(--md1-surface-raised); border-radius:var(--md1-radius);
  padding:20rpx 24rpx 16rpx; margin-bottom:16rpx;
  width:100%; box-sizing:border-box;
  box-shadow:var(--md1-shadow-card);
}
.sc-title { font-size:24rpx; font-weight:700; color:var(--md1-primary); padding:0 0 8rpx; }

.list-item { display:flex; align-items:center; justify-content:space-between; min-height:88rpx; padding:6rpx 4rpx; border-radius:var(--md1-radius); box-sizing:border-box; }
.list-item:active { background:transparent; }
.page.theme-light .list-item:active { background:transparent; }
.item-icon { width:56rpx; margin-right:20rpx; text-align:center; flex-shrink:0; color:var(--md1-text-secondary); font-size:44rpx; }
.item-body { flex:1; min-width:0; }
.item-title { font-size:30rpx; color:var(--md1-text-primary); line-height:1.25; }
.item-support { font-size:23rpx; color:var(--md1-text-secondary); margin-top:4rpx; opacity:0.72; line-height:1.25; }
.item-right { flex-shrink:0; margin-left:16rpx; color:var(--md1-text-secondary); font-size:44rpx; }
.item-right.material-icons { font-family:'Material Symbols Sharp'; line-height:1; font-feature-settings:'liga'; }
.md1-switch {
  position:relative;
  width:72rpx; height:72rpx;
  line-height:72rpx;
  margin-left:20rpx; margin-right:0;
  color:var(--md1-primary);
  background:transparent;
  flex-shrink:0;
  overflow:visible;
  user-select:none;
}
.md1-switch-track {
  position:absolute; left:0; top:22rpx;
  width:72rpx;
  height:28rpx; border-radius:28rpx;
  background:var(--md1-switch-track);
  transition:background-color 90ms cubic-bezier(0.4,0,0.2,1), opacity 90ms cubic-bezier(0.4,0,0.2,1);
}
.md1-switch-ripple {
  position:absolute; left:-6rpx; top:16rpx;
  width:40rpx; height:40rpx; border-radius:50%;
  background:var(--md1-control-ripple);
  opacity:0; pointer-events:none;
  transform:scale(1);
}
.md1-switch-thumb {
  position:absolute; left:-6rpx; top:16rpx;
  width:40rpx; height:40rpx; border-radius:50%;
  background:var(--md1-switch-thumb);
  box-shadow:var(--md1-shadow-switch-thumb);
  transition:transform 90ms cubic-bezier(0.4,0,0.2,1), background-color 90ms cubic-bezier(0.4,0,0.2,1), box-shadow 90ms cubic-bezier(0.4,0,0.2,1);
}
.md1-switch.checked .md1-switch-track { background:currentColor; opacity:0.5; }
.md1-switch.checked .md1-switch-ripple { transform:translateX(40rpx); background:currentColor; }
.md1-switch.checked .md1-switch-thumb { transform:translateX(40rpx); background:var(--md1-primary); }
.md1-switch.pressed .md1-switch-thumb,
.md1-switch:active .md1-switch-thumb { box-shadow:var(--md1-shadow-switch-thumb-pressed); }
.md1-switch.animating .md1-switch-ripple { animation:md1-switch-ripple-left 300ms cubic-bezier(0.4,0,0.2,1); }
.md1-switch.checked.animating .md1-switch-ripple { animation:md1-switch-ripple-right 300ms cubic-bezier(0.4,0,0.2,1); }

@keyframes md1-switch-ripple-left {
  0% { transform:translateX(40rpx) scale(2.4); opacity:0; }
  30% { transform:translateX(0) scale(2.4); opacity:0.16; }
  100% { transform:translateX(0) scale(2.4); opacity:0; }
}
@keyframes md1-switch-ripple-right {
  0% { transform:translateX(0) scale(2.4); opacity:0; }
  30% { transform:translateX(40rpx) scale(2.4); opacity:0.16; }
  100% { transform:translateX(40rpx) scale(2.4); opacity:0; }
}

.import-field { margin-bottom:24rpx; }
.import-field label { display:block; font-size:22rpx; color:var(--md1-text-secondary); margin-bottom:8rpx; }
.import-textarea { width:100%; min-height:320rpx; box-sizing:border-box; padding:16rpx 20rpx; background:var(--md1-field); border-radius:var(--md1-radius); color:var(--md1-text-primary); font-size:24rpx; line-height:1.5; border:none; outline:none; font-family:-apple-system-font, system-ui, -apple-system, BlinkMacSystemFont, sans-serif; }
