<view class="page tab-component-root route-body settings-component theme-animated {{themeClass}} nav-{{navMode}}"
      bindtouchmove="onRippleTouchMove" bindtouchend="onRippleTouchEnd" bindtouchcancel="onRippleTouchCancel">
<scroll-view class="settings-scroll" scroll-y="true" enhanced="true" show-scrollbar="false" bindscroll="onRippleScroll">
    <view class="settings-scroll-inner">
    <view class="about-card">
      <image class="about-logo-img" src="{{logoSrc}}" mode="aspectFit" />
      <view class="about-version">v1.0.0</view>
      <view class="about-desc">Kigurumi 玩家 / 漫展现场交流辅助工具</view>
      <view class="about-links">
        <text class="about-link" bindtap="onOpenLicense">开源许可证</text>
        <text class="about-divider"> · </text>
        <text class="about-link" bindtap="onOpenPrivacy">隐私政策</text>
      </view>
    </view>

    <view class="settings-card">
      <view class="sc-title">系统与布局</view>
      <view class="list-item" data-ripple="1" capture-bind:tap="onRippleTap" capture-bind:longpress="onRippleLongPress" bindtap="onOpenThemeSheet">
        <text class="item-icon material-icons">palette</text>
        <view class="item-body"><view class="item-title">主题模式</view><view class="item-support">{{themeModeLabel}}</view></view>
        <text class="item-right material-icons sm">chevron_right</text>
      </view>
      <view class="list-item" data-ripple="1" capture-bind:tap="onRippleTap" capture-bind:longpress="onRippleLongPress" bindtap="onToggleNavMode">
        <text class="item-icon material-icons">bottom_navigation</text>
        <view class="item-body"><view class="item-title">导航模式</view><view class="item-support">{{navMode === 'drawer' ? '抽屉菜单' : '底栏导航'}}</view></view>
        <text class="item-right material-icons sm">chevron_right</text>
      </view>
    </view>

    <view class="settings-card">
      <view class="sc-title">字幕显示</view>
      <view class="list-item">
        <text class="item-icon material-icons">fit_screen</text>
        <view class="item-body"><view class="item-title">便捷字幕字体大小自适应</view><view class="item-support">{{settings.subtitleAutoFit ? '开启' : '关闭'}}</view></view>
        <view class="md1-switch {{settings.subtitleAutoFit ? 'checked' : ''}} {{switchAnimKey === 'subtitleAutoFit' ? 'animating' : ''}}" data-key="subtitleAutoFit" hover-class="pressed" hover-start-time="0" hover-stay-time="300" catchtap="onSwitchTap">
          <view class="md1-switch-track"></view>
          <view class="md1-switch-ripple" bindanimationend="onSwitchAnimationEnd"></view>
          <view class="md1-switch-thumb"></view>
        </view>
      </view>
      <view class="list-item">
        <text class="item-icon material-icons">format_bold</text>
        <view class="item-body"><view class="item-title">粗体字幕</view><view class="item-support">{{settings.subtitleBold ? '开启' : '关闭'}}</view></view>
        <view class="md1-switch {{settings.subtitleBold ? 'checked' : ''}} {{switchAnimKey === 'subtitleBold' ? 'animating' : ''}}" data-key="subtitleBold" hover-class="pressed" hover-start-time="0" hover-stay-time="300" catchtap="onSwitchTap">
          <view class="md1-switch-track"></view>
          <view class="md1-switch-ripple" bindanimationend="onSwitchAnimationEnd"></view>
          <view class="md1-switch-thumb"></view>
        </view>
      </view>
      <view class="list-item">
        <text class="item-icon material-icons">format_align_center</text>
        <view class="item-body"><view class="item-title">居中显示</view><view class="item-support">{{settings.subtitleCenter ? '开启' : '关闭'}}</view></view>
        <view class="md1-switch {{settings.subtitleCenter ? 'checked' : ''}} {{switchAnimKey === 'subtitleCenter' ? 'animating' : ''}}" data-key="subtitleCenter" hover-class="pressed" hover-start-time="0" hover-stay-time="300" catchtap="onSwitchTap">
          <view class="md1-switch-track"></view>
          <view class="md1-switch-ripple" bindanimationend="onSwitchAnimationEnd"></view>
          <view class="md1-switch-thumb"></view>
        </view>
      </view>
      <view class="list-item">
        <text class="item-icon material-icons">swap_vert</text>
        <view class="item-body"><view class="item-title">字幕旋转 180°</view><view class="item-support">{{settings.subtitleRotated180 ? '开启' : '关闭'}}</view></view>
        <view class="md1-switch {{settings.subtitleRotated180 ? 'checked' : ''}} {{switchAnimKey === 'subtitleRotated180' ? 'animating' : ''}}" data-key="subtitleRotated180" hover-class="pressed" hover-start-time="0" hover-stay-time="300" catchtap="onSwitchTap">
          <view class="md1-switch-track"></view>
          <view class="md1-switch-ripple" bindanimationend="onSwitchAnimationEnd"></view>
          <view class="md1-switch-thumb"></view>
        </view>
      </view>
    </view>

    <view class="settings-card">
      <view class="sc-title">语音播报</view>
      <view class="list-item">
        <text class="item-icon material-icons">record_voice_over</text>
        <view class="item-body"><view class="item-title">微信同声传译 TTS</view><view class="item-support">{{settings.ttsEnabled ? '开启' : '关闭'}}</view></view>
        <view class="md1-switch {{settings.ttsEnabled ? 'checked' : ''}} {{switchAnimKey === 'ttsEnabled' ? 'animating' : ''}}" data-key="ttsEnabled" hover-class="pressed" hover-start-time="0" hover-stay-time="300" catchtap="onSwitchTap">
          <view class="md1-switch-track"></view>
          <view class="md1-switch-ripple" bindanimationend="onSwitchAnimationEnd"></view>
          <view class="md1-switch-thumb"></view>
        </view>
      </view>
      <view class="list-item">
        <text class="item-icon material-icons">volume_up</text>
        <view class="item-body"><view class="item-title">发送后朗读</view><view class="item-support">{{settings.subtitlePlayOnSend ? '开启' : '关闭'}}</view></view>
        <view class="md1-switch {{settings.subtitlePlayOnSend ? 'checked' : ''}} {{switchAnimKey === 'subtitlePlayOnSend' ? 'animating' : ''}}" data-key="subtitlePlayOnSend" hover-class="pressed" hover-start-time="0" hover-stay-time="300" catchtap="onSwitchTap">
          <view class="md1-switch-track"></view>
          <view class="md1-switch-ripple" bindanimationend="onSwitchAnimationEnd"></view>
          <view class="md1-switch-thumb"></view>
        </view>
      </view>
    </view>

    <view class="settings-card">
      <view class="sc-title">数据管理</view>
      <view class="list-item" data-ripple="1" capture-bind:tap="onRippleTap" capture-bind:longpress="onRippleLongPress" bindtap="onExportAll">
        <text class="item-icon material-icons">ios_share</text>
        <view class="item-body"><view class="item-title">导出所有预设</view><view class="item-support">导出字幕和音效预设到剪贴板</view></view>
        <text class="item-right material-icons sm">chevron_right</text>
      </view>
      <view class="list-item" data-ripple="1" capture-bind:tap="onRippleTap" capture-bind:longpress="onRippleLongPress" bindtap="onShowImportEditor">
        <text class="item-icon material-icons">folder_open</text>
        <view class="item-body"><view class="item-title">导入预设</view><view class="item-support">粘贴导出的 JSON 预设文本</view></view>
        <text class="item-right material-icons sm">chevron_right</text>
      </view>
      <view class="list-item" data-ripple="1" capture-bind:tap="onRippleTap" capture-bind:longpress="onRippleLongPress" bindtap="onClearAll">
        <text class="item-icon material-icons" style="color: var(--md1-error);">delete_sweep</text>
        <view class="item-body"><view class="item-title" style="color: var(--md1-error);">清除所有数据</view><view class="item-support">恢复出厂设置，此操作不可撤销</view></view>
        <text class="item-right material-icons sm" style="color: var(--md1-error);">chevron_right</text>
      </view>
    </view>

    <view class="settings-bottom-spacer"></view>
    </view>
  </scroll-view>
</view>

<view class="sheet-mask theme-animated {{themeClass}} nav-{{navMode}}" wx:if="{{showThemeSheet}}" bindtap="onCloseThemeSheet"
      bindtouchmove="onRippleTouchMove" bindtouchend="onRippleTouchEnd" bindtouchcancel="onRippleTouchCancel">
  <view class="sheet-panel theme-mode-sheet" catchtap="noop">
    <view class="sheet-header">
      <text class="sheet-title">主题模式</text>
      <text class="material-icons lg" bindtap="onCloseThemeSheet" style="padding:8rpx;">close</text>
    </view>
    <view class="sheet-body theme-mode-list">
      <view class="theme-mode-item {{settings.themeMode === item.value ? 'selected' : ''}}"
            wx:for="{{themeOptions}}" wx:key="value"
            data-mode="{{item.value}}" data-ripple="1"
            capture-bind:tap="onRippleTap" capture-bind:longpress="onRippleLongPress" bindtap="onThemeModeTap">
        <text class="material-icons theme-mode-icon">{{item.icon}}</text>
        <view class="theme-mode-body">
          <view class="theme-mode-title">{{item.label}}</view>
          <view class="theme-mode-support">{{item.support}}</view>
        </view>
        <text class="material-icons theme-mode-check" wx:if="{{settings.themeMode === item.value}}">check</text>
      </view>
    </view>
  </view>
</view>

<view class="sheet-mask theme-animated {{themeClass}} nav-{{navMode}}" wx:if="{{showImportEditor}}" bindtap="onCloseImportEditor"
      bindtouchmove="onRippleTouchMove" bindtouchend="onRippleTouchEnd" bindtouchcancel="onRippleTouchCancel">
  <view class="sheet-panel" catchtap="noop">
    <view class="sheet-header"><text class="sheet-title">导入预设</text><text class="material-icons lg" bindtap="onCloseImportEditor" style="padding:8rpx;">close</text></view>
    <view class="sheet-body">
      <view class="import-field"><label class="import-label">粘贴导出的 JSON 数据</label><textarea class="import-textarea" value="{{importData}}" bindinput="onImportDataInput" placeholder='{"subtitle":{...},"soundboard":{...}}' placeholder-class="textarea-placeholder" maxlength="-1" /></view>
    </view>
    <view class="sheet-footer"><view class="btn-text-sm" data-ripple="1" capture-bind:tap="onRippleTap" capture-bind:longpress="onRippleLongPress" bindtap="onCloseImportEditor">取消</view><view class="btn-filled-sm" data-ripple="1" data-ripple-color="rgb(255,255,255)" capture-bind:tap="onRippleTap" capture-bind:longpress="onRippleLongPress" bindtap="onDoImport">导入</view></view>
  </view>
</view>
<view class="ripple-host">
  <view class="sc-ripple-clip" wx:for="{{rippleList}}" wx:key="id" style="{{item.clipStyle}}">
    <view class="sc-ripple {{item.hold ? 'sc-ripple-hold' : ''}}" data-id="{{item.id}}" style="{{item.style}}" bindanimationend="onRippleAnimationEnd"></view>
  </view>
</view>
