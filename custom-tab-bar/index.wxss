@import "../utils/icons.wxss";

.tab-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 700;
  pointer-events: none;
  font-family: -apple-system-font, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
  --md1-shadow-bottombar: 0 -3rpx 4rpx -2rpx rgba(0, 0, 0, 0.16), 0 -6rpx 9rpx 0 rgba(0, 0, 0, 0.10), 0 -2rpx 12rpx 0 rgba(0, 0, 0, 0.08);
}

.tabbar {
  position: relative;
  min-height: 112rpx;
  padding: 8rpx 12rpx calc(10rpx + env(safe-area-inset-bottom));
  background: #2a2e30;
  border-top: 1px solid rgba(255, 255, 255, 0.10);
  box-shadow: var(--md1-shadow-bottombar);
  display: flex;
  align-items: center;
  box-sizing: border-box;
  pointer-events: auto;
  overflow: hidden;
}

.tab-shell.theme-light .tabbar {
  background: #FFFFFF;
  border-top-color: rgba(0, 0, 0, 0.08);
}

.tab-shell.subtitle-current .tabbar {
  box-shadow: none;
}

.tab-item {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
  height: 88rpx;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #C2C2C2;
  gap: 2rpx;
  -webkit-tap-highlight-color: transparent;
}

.tab-shell.theme-light .tab-item {
  color: #495156;
}

.tab-item.active {
  color: #038387;
  background: transparent;
}

.tab-item.active .tab-icon,
.tab-item.active .tab-label {
  color: #038387;
}

.tab-item:active {
  background: transparent;
}

.tab-icon {
  font-size: 44rpx;
  line-height: 1;
}

.tab-label {
  font-family: -apple-system-font, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 24rpx;
  line-height: 1.2;
  white-space: nowrap;
}

.tab-driver {
  position: absolute;
  left: 0;
  bottom: env(safe-area-inset-bottom);
  height: 4rpx;
  display: flex;
  justify-content: center;
  pointer-events: none;
  transition: transform 300ms linear;
  will-change: transform;
}

.tab-driver-inner {
  width: 56rpx;
  height: 4rpx;
  border-radius: 4rpx 4rpx 0 0;
  background: #038387;
}

.ripple-host {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1200;
  pointer-events: none;
  overflow: hidden;
}

.sc-ripple-clip {
  position: absolute;
  pointer-events: none;
  overflow: hidden;
}

.sc-ripple {
  position: absolute;
  border-radius: 100%;
  opacity: 0.3;
  transform: scale(0.1);
  transform-origin: center center;
  animation: scRipple 0.6s ease-out;
  animation-fill-mode: forwards;
}

@keyframes scRipple {
  from { transform: scale(0.1); opacity: 0.3; }
  to { transform: scale(2.5); opacity: 0; }
}
