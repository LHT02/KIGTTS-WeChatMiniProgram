@import "./utils/icons.wxss";
@import "./utils/logo.wxss";
@import "./templates/shell.wxss";

/* ═══════════════════════════════════════════════════════════════
   KIGTTS — 暗色主题 (默认)
   主色: #038387 · 圆角: 8rpx (4dp) · 参考 Android 端 UiTokens
   色值对齐: android-app/MainActivity.kt KgtDarkColors
   ═══════════════════════════════════════════════════════════════ */

page {
  background: #121416;
  color: #E4E8EB;
  font-family: system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 28rpx; line-height: 1.45;
  --md1-surface: #1D2023;
  --md1-surface-raised: #262A2E;
  --md1-surface-menu: #303335;
  --md1-primary: #038387;
  --md1-text-primary: #E4E8EB;
  --md1-text-secondary: #B6BEC4;
  --md1-text-hint: #757F87;
  --md1-error: #cf6679;
  --md1-radius-sm: 8rpx;
  --md1-radius-md: 8rpx;
  --md1-radius-lg: 8rpx;
  --md1-radius: 8rpx;
  --md1-divider: rgba(255,255,255,0.10);
  --md1-field: rgba(255,255,255,0.08);
  --md1-shadow-card: 0 6rpx 2rpx -4rpx rgba(0,0,0,0.14), 0 4rpx 4rpx 0 rgba(0,0,0,0.098), 0 2rpx 10rpx 0 rgba(0,0,0,0.084);
  --md1-shadow-card-tight: 0 6rpx 2rpx -4rpx rgba(0,0,0,0.14), 0 4rpx 2rpx 0 rgba(0,0,0,0.098), 0 2rpx 10rpx 0 rgba(0,0,0,0.084);
  --md1-shadow-card-up: 0 -6rpx 2rpx -4rpx rgba(0,0,0,0.14), 0 -4rpx 4rpx 0 rgba(0,0,0,0.098), 0 -2rpx 10rpx 0 rgba(0,0,0,0.084);
  --md1-shadow-appbar: 0 4rpx 4rpx -2rpx rgba(0,0,0,0.18), 0 8rpx 10rpx 0 rgba(0,0,0,0.11), 0 2rpx 14rpx 0 rgba(0,0,0,0.09);
  --md1-shadow-appbar-up: 0 -4rpx 4rpx -2rpx rgba(0,0,0,0.18), 0 -8rpx 10rpx 0 rgba(0,0,0,0.11), 0 -2rpx 14rpx 0 rgba(0,0,0,0.09);
  --md1-shadow-bottombar: 0 -3rpx 4rpx -2rpx rgba(0,0,0,0.16), 0 -6rpx 9rpx 0 rgba(0,0,0,0.10), 0 -2rpx 12rpx 0 rgba(0,0,0,0.08);
  --md1-shadow-fab: 0 6rpx 10rpx -2rpx rgba(0,0,0,0.14), 0 12rpx 20rpx 0 rgba(0,0,0,0.098), 0 2rpx 36rpx 0 rgba(0,0,0,0.084);
  --md1-shadow-drag: 0 12rpx 20rpx -4rpx rgba(0,0,0,0.20), 0 20rpx 28rpx 2rpx rgba(0,0,0,0.14), 0 6rpx 36rpx 4rpx rgba(0,0,0,0.12);
  --md1-shadow-switch-thumb: 0 2rpx 2rpx 0 rgba(0,0,0,0.20), 0 2rpx 4rpx 0 rgba(0,0,0,0.14), 0 4rpx 2rpx -2rpx rgba(0,0,0,0.12);
  --md1-shadow-switch-thumb-pressed: 0 4rpx 4rpx 0 rgba(0,0,0,0.22), 0 2rpx 8rpx 0 rgba(0,0,0,0.16);
}

/* 每个页面的根容器持有主题变量，通过 themeClass 切换 */
.page {
  --md1-bg: #121416;
  --md1-surface: #1D2023;
  --md1-surface-raised: #262A2E;
  --md1-surface-menu: #303335;
  --md1-field: rgba(255,255,255,0.08);
  --md1-divider: rgba(255,255,255,0.10);
  --md1-shadow-card: 0 6rpx 2rpx -4rpx rgba(0,0,0,0.14), 0 4rpx 4rpx 0 rgba(0,0,0,0.098), 0 2rpx 10rpx 0 rgba(0,0,0,0.084);
  --md1-shadow-card-tight: 0 6rpx 2rpx -4rpx rgba(0,0,0,0.14), 0 4rpx 2rpx 0 rgba(0,0,0,0.098), 0 2rpx 10rpx 0 rgba(0,0,0,0.084);
  --md1-shadow-card-up: 0 -6rpx 2rpx -4rpx rgba(0,0,0,0.14), 0 -4rpx 4rpx 0 rgba(0,0,0,0.098), 0 -2rpx 10rpx 0 rgba(0,0,0,0.084);
  --md1-shadow-appbar: 0 4rpx 4rpx -2rpx rgba(0,0,0,0.18), 0 8rpx 10rpx 0 rgba(0,0,0,0.11), 0 2rpx 14rpx 0 rgba(0,0,0,0.09);
  --md1-shadow-appbar-up: 0 -4rpx 4rpx -2rpx rgba(0,0,0,0.18), 0 -8rpx 10rpx 0 rgba(0,0,0,0.11), 0 -2rpx 14rpx 0 rgba(0,0,0,0.09);
  --md1-shadow-bottombar: 0 -3rpx 4rpx -2rpx rgba(0,0,0,0.16), 0 -6rpx 9rpx 0 rgba(0,0,0,0.10), 0 -2rpx 12rpx 0 rgba(0,0,0,0.08);
  --md1-shadow-fab: 0 6rpx 10rpx -2rpx rgba(0,0,0,0.14), 0 12rpx 20rpx 0 rgba(0,0,0,0.098), 0 2rpx 36rpx 0 rgba(0,0,0,0.084);
  --md1-shadow-drag: 0 12rpx 20rpx -4rpx rgba(0,0,0,0.20), 0 20rpx 28rpx 2rpx rgba(0,0,0,0.14), 0 6rpx 36rpx 4rpx rgba(0,0,0,0.12);
  --md1-shadow-switch-thumb: 0 2rpx 2rpx 0 rgba(0,0,0,0.20), 0 2rpx 4rpx 0 rgba(0,0,0,0.14), 0 4rpx 2rpx -2rpx rgba(0,0,0,0.12);
  --md1-shadow-switch-thumb-pressed: 0 4rpx 4rpx 0 rgba(0,0,0,0.22), 0 2rpx 8rpx 0 rgba(0,0,0,0.16);

  --md1-primary: #038387;
  --md1-primary-dark: #006b6f;
  --md1-on-primary: #ffffff;

  --md1-text-primary: #E4E8EB;
  --md1-text-secondary: #B6BEC4;
  --md1-text-disabled: rgba(255,255,255,0.26);
  --md1-text-hint: #757F87;

  --md1-error: #cf6679;
  --md1-radius-sm: 8rpx;
  --md1-radius-md: 8rpx;
  --md1-radius-lg: 8rpx;
  --md1-radius: 8rpx;

  --color-primary: var(--md1-primary);
  --color-bg: var(--md1-bg);
  --color-bg-card: var(--md1-surface-raised);
  --color-bg-input: var(--md1-field);
  --color-border: var(--md1-divider);
  --color-text: var(--md1-text-primary);
  --color-text-secondary: var(--md1-text-secondary);
  --color-text-muted: var(--md1-text-hint);
  --color-danger: var(--md1-error);
}

/* 浅色主题 — 对齐 Android KgtLightColors */
.theme-light {
  --md1-bg: #F1F3F5;
  --md1-surface: #FFFFFF;
  --md1-surface-raised: #FFFFFF;
  --md1-surface-menu: #FFFFFF;
  --md1-field: rgba(0,0,0,0.06);
  --md1-divider: rgba(0,0,0,0.08);

  --md1-text-primary: #111417;
  --md1-text-secondary: #495156;
  --md1-text-disabled: rgba(0,0,0,0.26);
  --md1-text-hint: #757F87;
}

.theme-light .sheet-panel { box-shadow: var(--md1-shadow-appbar-up); }
.sheet-mask.theme-light,
.dialog-mask.theme-light,
.preview-mask.theme-light { background: rgba(0,0,0,0.35); }
.theme-light .card-watermark { color: rgba(255,255,255,0.15); }
.theme-light .card-title,
.theme-light .preview-title { color: #fff; }
.theme-light .card-note,
.theme-light .preview-note { color: rgba(255,255,255,0.78); }

/* ═══════ Buttons ═══════ */

.btn-filled {
  display: inline-flex; align-items: center; justify-content: center;
  height: 72rpx; padding: 0 32rpx;
  border-radius: var(--md1-radius-lg);
  background: var(--md1-primary); color: var(--md1-on-primary);
  font-size: 28rpx; font-weight: 500; border: none; text-align: center;
  box-shadow: var(--md1-shadow-card);
}
.btn-outlined {
  display: inline-flex; align-items: center; justify-content: center;
  height: 72rpx; padding: 0 32rpx;
  border-radius: var(--md1-radius-lg);
  background: transparent; color: var(--md1-primary);
  border: 1px solid rgba(3,131,135,0.5);
  font-size: 28rpx; font-weight: 500; text-align: center;
}
.btn-text {
  display: inline-flex; align-items: center; justify-content: center;
  height: 72rpx; padding: 0 24rpx;
  border-radius: var(--md1-radius-sm);
  background: transparent; color: var(--md1-primary);
  font-size: 28rpx; font-weight: 500; border: none; text-align: center;
}
.btn-filled-sm {
  display: inline-flex; align-items: center; justify-content: center;
  height: 56rpx; padding: 0 20rpx;
  border-radius: var(--md1-radius-sm);
  background: var(--md1-primary); color: var(--md1-on-primary);
  font-size: 24rpx; font-weight: 500; border: none; text-align: center;
  box-shadow: var(--md1-shadow-card);
}
.btn-outlined-sm {
  display: inline-flex; align-items: center; justify-content: center;
  height: 56rpx; padding: 0 20rpx;
  border-radius: var(--md1-radius-sm);
  background: transparent; color: var(--md1-primary);
  border: 1px solid rgba(3,131,135,0.5);
  font-size: 24rpx; font-weight: 500; text-align: center;
}
.btn-text-sm {
  display: inline-flex; align-items: center; justify-content: center;
  height: 56rpx; padding: 0 16rpx;
  border-radius: var(--md1-radius);
  background: transparent; color: var(--md1-primary);
  font-size: 24rpx; font-weight: 500; border: none; text-align: center;
}

/* ═══════ Icon Buttons ═══════ */

.icon-btn {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  display: inline-flex; align-items: center; justify-content: center;
  background: transparent; color: var(--md1-text-primary);
  font-size: 48rpx; border: none;
}
.icon-btn:active { background: transparent; }
.icon-btn-sm {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  display: inline-flex; align-items: center; justify-content: center;
  background: transparent; color: var(--md1-text-primary);
  font-size: 48rpx; border: none;
}
.icon-btn-sm:active { background: transparent; }
.icon-btn-sm.sel { background: transparent; color: var(--md1-text-primary); }
.icon-btn .material-icons, .icon-btn-sm .material-icons { font-family: 'Material Symbols Sharp'; line-height: 1; }
.material-icons { font-size: 52rpx; font-weight: 500; }
.material-icons.sm { font-size: 44rpx; }
.material-icons.lg { font-size: 60rpx; }
.icon-btn .material-icons { font-size: 56rpx; }
.icon-btn-sm .material-icons { font-size: 48rpx; }
.icon-btn-sm .material-icons.sm { font-size: 44rpx; }

.nav-menu { flex-shrink: 0; color: var(--md1-text-primary); }
.nav-actions { margin-left: auto; display: flex; align-items: center; gap: 4rpx; }

/* ═══════ Text Field ═══════ */

.md-text-field {
  display: flex; align-items: center; height: 88rpx;
  border-bottom: 2px solid rgba(255,255,255,0.12);
  background: transparent;
}
.md-text-field input {
  flex: 1; height: 100%; padding: 0 8rpx;
  background: transparent; color: var(--md1-text-primary);
  font-size: 32rpx; border: none; outline: none;
  caret-color: var(--md1-primary);
}

/* ═══════ Chip ═══════ */

.md-chip {
  display: inline-flex; align-items: center;
  height: 56rpx; padding: 0 20rpx;   border-radius: var(--md1-radius-lg);
  background: rgba(255,255,255,0.12); color: var(--md1-text-primary);
  font-size: 24rpx; font-weight: 500; border: none; white-space: nowrap; flex-shrink: 0;
}
.md-chip.outlined { background: transparent; border: 1px solid rgba(255,255,255,0.15); color: var(--md1-text-secondary); }
.md-chip.selected { background: rgba(3,131,135,0.18); color: #4dd0e1; }

/* ═══════ Card ═══════ */

.md-card {
  background: var(--md1-surface-raised); border-radius: var(--md1-radius-lg); padding: 28rpx;
  box-shadow: var(--md1-shadow-card);
}
.md-card-filled {
  background: var(--md1-surface-raised); border-radius: var(--md1-radius-lg); padding: 28rpx;
  box-shadow: var(--md1-shadow-card);
}

/* ═══════ Bottom Sheet ═══════ */

.sheet-mask {
  position: fixed; top:0;left:0;right:0;bottom:0;
  background: rgba(0,0,0,0.5); z-index:200;
  display: flex; align-items: flex-end; justify-content: center;
}
.sheet-panel {
  background: var(--md1-surface-menu);
  border-radius: var(--md1-radius-lg) var(--md1-radius-lg) 0 0;
  width: 100%; max-height: 80vh; display: flex; flex-direction: column;
  box-shadow: var(--md1-shadow-appbar-up);
}
.sheet-panel .sheet-header {
  padding: 28rpx 32rpx; display: flex; justify-content: space-between; align-items: center;
  border-bottom: 1px solid var(--md1-divider);
}
.sheet-panel .sheet-title { font-size: 32rpx; font-weight: 500; color: var(--md1-text-primary); }
.sheet-panel .sheet-body { flex: 1; padding: 24rpx 32rpx; overflow-y: auto; }
.sheet-panel .sheet-body.scrollable { padding: 0 32rpx; }
.sheet-panel .sheet-footer {
  display: flex; gap: 16rpx; justify-content: flex-end;
  padding: 20rpx 32rpx; border-top: 1px solid var(--md1-divider);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

/* ═══════ List Item ═══════ */

.section { margin: 24rpx 20rpx; }
.list-item {
  display: flex; align-items: center; justify-content: space-between;
  min-height: 80rpx; padding: 16rpx 28rpx;
  background: var(--md1-surface-raised); border-bottom: 1px solid var(--md1-divider);
}
.list-item:first-child { border-radius: var(--md1-radius-lg) var(--md1-radius-lg) 0 0; }
.list-item:last-child  { border-radius: 0 0 var(--md1-radius-lg) var(--md1-radius-lg); border-bottom: none; }
.list-item .item-left { display: flex; align-items: center; gap: 32rpx; flex:1; min-width:0; }
.list-item .item-icon {
  font-family: 'Material Symbols Sharp', sans-serif; font-weight: 400; font-style: normal;
  font-size: 44rpx; width: 56rpx; text-align: center; color: var(--md1-text-secondary);
  line-height: 1; font-feature-settings: 'liga'; -webkit-font-smoothing: antialiased;
}
.list-item .item-body { flex:1; min-width:0; }
.list-item .item-title { font-size: 28rpx; color: var(--md1-text-primary); }
.list-item .item-support { font-size: 22rpx; color: var(--md1-text-hint); margin-top: 4rpx; }
.list-item .item-right { flex-shrink:0; margin-left:24rpx; color: var(--md1-text-secondary); }
.list-item .item-right.material-icons { font-family: 'Material Symbols Sharp', sans-serif; font-weight: 400; font-style: normal; line-height: 1; font-feature-settings: 'liga'; -webkit-font-smoothing: antialiased; }
.list-item switch { flex-shrink:0; }
.slider-item { flex-direction: column; align-items: stretch; padding: 24rpx 32rpx; }
.slider-item .item-left { margin-bottom: 16rpx; }
.slider-item slider { width: 100%; }

/* ═══════ Section Label ═══════ */

.section-label {
  font-size: 22rpx; color: var(--md1-primary); font-weight: 500;
  letter-spacing: 0.5rpx; padding: 20rpx 36rpx 8rpx;
}

/* ═══════ Dialog ═══════ */

.dialog-mask { position:fixed; top:0;left:0;right:0;bottom:0; background:rgba(0,0,0,0.52); z-index:200; display:flex; align-items:center; justify-content:center; padding:56rpx; }
.dialog-box {
  background:var(--md1-surface-menu, #303335); border-radius:var(--md1-radius);
  width:500rpx; max-width:100%; padding:40rpx;
  box-sizing:border-box;
  box-shadow:var(--md1-shadow-card);
}
.dialog-box .dialog-text { font-size:28rpx; color:var(--md1-text-primary); line-height:1.6; margin-bottom:40rpx; }
.dialog-box .dialog-footer { display:flex; gap:16rpx; justify-content:flex-end; }

/* ═══════ Utility ═══════ */

.flex-row { display:flex; flex-direction:row; align-items:center; }
.flex-col { display:flex; flex-direction:column; }
.flex-1 { flex:1; min-width:0; }
.flex-center { display:flex; align-items:center; justify-content:center; }
.flex-between { display:flex; align-items:center; justify-content:space-between; }
.text-ellipsis { overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.safe-bottom { padding-bottom: constant(safe-area-inset-bottom); padding-bottom: env(safe-area-inset-bottom); }
.empty-state { padding: 160rpx 0; text-align: center; color: var(--md1-text-hint); font-size: 26rpx; }

/* ═══════ sc-ui Inspired Ripple ═══════ */

.btn-filled, .btn-outlined, .btn-text,
.btn-filled-sm, .btn-outlined-sm, .btn-text-sm,
.icon-btn, .icon-btn-sm,
.md-chip, .group-chip, .quick-chip, .list-item,
.send-btn, .group-edit-segment, .card-toolbar-toggle,
.btn-micro, .card-edit-btn, .link-icon-btn, .icon-chip,
.quick-list-item, .sheet-list-item, .sound-card,
.slist-play, .sgrid-play, .preview-close-btn,
.nav-back, .tool-toggle, .item-row, .icon-cell, .color-dot {
  position: relative;
  overflow: hidden;
  -webkit-tap-highlight-color: transparent;
}

.btn-filled::after, .btn-outlined::after, .btn-text::after,
.btn-filled-sm::after, .btn-outlined-sm::after, .btn-text-sm::after,
.icon-btn::after, .icon-btn-sm::after,
.md-chip::after, .group-chip::after, .quick-chip::after, .list-item::after,
.send-btn::after, .group-edit-segment::after, .card-toolbar-toggle::after,
.btn-micro::after, .card-edit-btn::after, .link-icon-btn::after, .icon-chip::after,
.quick-list-item::after, .sheet-list-item::after, .sound-card::after,
.slist-play::after, .sgrid-play::after, .preview-close-btn::after,
.nav-back::after, .tool-toggle::after, .item-row::after, .icon-cell::after, .color-dot::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.30);
  opacity: 0;
  pointer-events: none;
  transform: translate(-50%, -50%) scale(0.1);
  transform-origin: center center;
}

.theme-light .btn-filled::after, .theme-light .btn-outlined::after, .theme-light .btn-text::after,
.theme-light .btn-filled-sm::after, .theme-light .btn-outlined-sm::after, .theme-light .btn-text-sm::after,
.theme-light .icon-btn::after, .theme-light .icon-btn-sm::after,
.theme-light .md-chip::after, .theme-light .group-chip::after, .theme-light .quick-chip::after, .theme-light .list-item::after,
.theme-light .send-btn::after, .theme-light .group-edit-segment::after, .theme-light .card-toolbar-toggle::after,
.theme-light .btn-micro::after, .theme-light .card-edit-btn::after, .theme-light .link-icon-btn::after, .theme-light .icon-chip::after,
.theme-light .quick-list-item::after, .theme-light .sheet-list-item::after, .theme-light .sound-card::after,
.theme-light .slist-play::after, .theme-light .sgrid-play::after, .theme-light .preview-close-btn::after,
.theme-light .nav-back::after, .theme-light .tool-toggle::after, .theme-light .item-row::after, .theme-light .icon-cell::after, .theme-light .color-dot::after {
  background: rgba(0,0,0,0.18);
}

.btn-filled::after, .btn-filled-sm::after,
.group-edit-segment::after,
.send-btn.enabled::after {
  background: rgba(255,255,255,0.34);
}

.btn-filled:active::after, .btn-outlined:active::after, .btn-text:active::after,
.btn-filled-sm:active::after, .btn-outlined-sm:active::after, .btn-text-sm:active::after,
.icon-btn:active::after, .icon-btn-sm:active::after,
.md-chip:active::after, .group-chip:active::after, .quick-chip:active::after, .list-item:active::after,
.send-btn:active::after, .group-edit-segment:active::after, .card-toolbar-toggle:active::after,
.btn-micro:active::after, .card-edit-btn:active::after, .link-icon-btn:active::after, .icon-chip:active::after,
.quick-list-item:active::after, .sheet-list-item:active::after, .sound-card:active::after,
.slist-play:active::after, .sgrid-play:active::after, .preview-close-btn:active::after,
.nav-back:active::after, .tool-toggle:active::after, .item-row:active::after, .icon-cell:active::after, .color-dot:active::after {
  animation: scRipple 0.6s ease-out;
  animation-fill-mode: forwards;
}

/* ═══════ Transitions ═══════ */

.btn-filled, .btn-outlined, .btn-text,
.btn-filled-sm, .btn-outlined-sm, .btn-text-sm,
.icon-btn, .icon-btn-sm, .md-chip, .group-chip,
.sound-card, .quick-chip, .list-item, .log-row, .kigtts-logo-mark,
.name-card, .subtitle-card, .sheet-panel, .preview-dialog,
.sheet-mask, .dialog-mask, .card-toolbar, .input-bar, .page {
  transition: background-color 0.18s cubic-bezier(0.4,0,0.2,1), color 0.18s cubic-bezier(0.4,0,0.2,1), box-shadow 0.18s cubic-bezier(0.4,0,0.2,1), border-color 0.18s cubic-bezier(0.4,0,0.2,1), opacity 0.18s cubic-bezier(0.4,0,0.2,1);
}
.sheet-mask, .dialog-mask, .preview-mask { animation: fadeIn 0.14s cubic-bezier(0.4,0,0.2,1); }
.sheet-panel { animation: slideUp 0.18s cubic-bezier(0.4,0,0.2,1); }
.dot { transition: all 0.16s cubic-bezier(0.4,0,0.2,1); }
page { animation: pageIn 0.14s cubic-bezier(0.4,0,0.2,1); }

@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
@keyframes pageIn { from { opacity: 0.6; } to { opacity: 1; } }
@keyframes scRipple {
  from { transform: translate(-50%, -50%) scale(0.1); opacity: 0.30; }
  to { transform: translate(-50%, -50%) scale(28); opacity: 0; }
}
