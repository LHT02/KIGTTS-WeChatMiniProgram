@import "./utils/icons.wxss";
@import "./utils/logo.wxss";
@import "./templates/shell.wxss";

/* ═══════════════════════════════════════════════════════════════
   KIGTTS — 暗色主题 (默认)
   主色: #038387 · 圆角: 8rpx (4dp) · 参考 Android 端 UiTokens
   暗色表面使用 MD 暗色海拔灰阶，避免小程序渲染偏蓝
   ═══════════════════════════════════════════════════════════════ */

page {
  background: #131416;
  color: #E6E6E6;
  font-family: -apple-system-font, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 28rpx; line-height: 1.45;
  --md1-surface: #34383b;
  --md1-surface-raised: #2a2e30;
  --md1-surface-menu: #34383b;
  --md1-primary: #038387;
  --md1-text-primary: #E6E6E6;
  --md1-text-secondary: #C2C2C2;
  --md1-text-hint: #8C8C8C;
  --md1-error: #cf6679;
  --md1-radius-sm: 8rpx;
  --md1-radius-md: 8rpx;
  --md1-radius-lg: 8rpx;
  --md1-radius: 8rpx;
  --md1-divider: rgba(255,255,255,0.10);
  --md1-field: rgba(255,255,255,0.08);
  --md1-shadow-card: 0 6rpx 2rpx -4rpx rgba(0,0,0,0.14), 0 4rpx 4rpx 0 rgba(0,0,0,0.098), 0 2rpx 10rpx 0 rgba(0,0,0,0.084);
  --md1-shadow-card-tight: 0 6rpx 2rpx -4rpx rgba(0,0,0,0.14), 0 4rpx 2rpx 0 rgba(0,0,0,0.098), 0 2rpx 10rpx 0 rgba(0,0,0,0.084);
  --md1-shadow-card-up: 0 -6rpx 2rpx -4rpx rgba(0,0,0,0.14), 0 -4rpx 4rpx 0 rgba(0,0,0,0.098), 0 -2rpx 10rpx 0 rgba(0,0,0,0.084);
  --md1-shadow-appbar: 0 4rpx 4rpx -2rpx rgba(0,0,0,0.18), 0 8rpx 10rpx 0 rgba(0,0,0,0.11), 0 2rpx 14rpx 0 rgba(0,0,0,0.09);
  --md1-shadow-appbar-up: 0 -4rpx 4rpx -2rpx rgba(0,0,0,0.18), 0 -8rpx 10rpx 0 rgba(0,0,0,0.11), 0 -2rpx 14rpx 0 rgba(0,0,0,0.09);
  --md1-shadow-bottombar: 0 -3rpx 4rpx -2rpx rgba(0,0,0,0.16), 0 -6rpx 9rpx 0 rgba(0,0,0,0.10), 0 -2rpx 12rpx 0 rgba(0,0,0,0.08);
  --md1-shadow-fab: 0 6rpx 10rpx -2rpx rgba(0,0,0,0.14), 0 12rpx 20rpx 0 rgba(0,0,0,0.098), 0 2rpx 36rpx 0 rgba(0,0,0,0.084);
  --md1-shadow-drag: 0 12rpx 20rpx -4rpx rgba(0,0,0,0.20), 0 20rpx 28rpx 2rpx rgba(0,0,0,0.14), 0 6rpx 36rpx 4rpx rgba(0,0,0,0.12);
  --md1-shadow-switch-thumb: 0 2rpx 2rpx 0 rgba(0,0,0,0.20), 0 2rpx 4rpx 0 rgba(0,0,0,0.14), 0 4rpx 2rpx -2rpx rgba(0,0,0,0.12);
  --md1-shadow-switch-thumb-pressed: 0 4rpx 4rpx 0 rgba(0,0,0,0.22), 0 2rpx 8rpx 0 rgba(0,0,0,0.16);
  --md1-control-border: rgba(255,255,255,0.62);
  --md1-control-ripple: #ffffff;
  --md1-switch-track: rgba(255,255,255,0.38);
  --md1-switch-thumb: #fafafa;
}

input,
textarea,
button,
.input-placeholder,
.textarea-placeholder {
  font-family: -apple-system-font, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
}

.input-placeholder,
.textarea-placeholder {
  color: var(--md1-text-hint);
}

/* 每个页面的根容器持有主题变量，通过 themeClass 切换 */
.page {
  animation: none;
  transform-origin: center center;
  --md1-bg: #131416;
  --md1-surface: #34383b;
  --md1-surface-raised: #2a2e30;
  --md1-surface-menu: #34383b;
  --md1-field: rgba(255,255,255,0.08);
  --md1-divider: rgba(255,255,255,0.10);
  --md1-shadow-card: 0 6rpx 2rpx -4rpx rgba(0,0,0,0.14), 0 4rpx 4rpx 0 rgba(0,0,0,0.098), 0 2rpx 10rpx 0 rgba(0,0,0,0.084);
  --md1-shadow-card-tight: 0 6rpx 2rpx -4rpx rgba(0,0,0,0.14), 0 4rpx 2rpx 0 rgba(0,0,0,0.098), 0 2rpx 10rpx 0 rgba(0,0,0,0.084);
  --md1-shadow-card-up: 0 -6rpx 2rpx -4rpx rgba(0,0,0,0.14), 0 -4rpx 4rpx 0 rgba(0,0,0,0.098), 0 -2rpx 10rpx 0 rgba(0,0,0,0.084);
  --md1-shadow-appbar: 0 4rpx 4rpx -2rpx rgba(0,0,0,0.18), 0 8rpx 10rpx 0 rgba(0,0,0,0.11), 0 2rpx 14rpx 0 rgba(0,0,0,0.09);
  --md1-shadow-appbar-up: 0 -4rpx 4rpx -2rpx rgba(0,0,0,0.18), 0 -8rpx 10rpx 0 rgba(0,0,0,0.11), 0 -2rpx 14rpx 0 rgba(0,0,0,0.09);
  --md1-shadow-bottombar: 0 -3rpx 4rpx -2rpx rgba(0,0,0,0.16), 0 -6rpx 9rpx 0 rgba(0,0,0,0.10), 0 -2rpx 12rpx 0 rgba(0,0,0,0.08);
  --md1-shadow-fab: 0 6rpx 10rpx -2rpx rgba(0,0,0,0.14), 0 12rpx 20rpx 0 rgba(0,0,0,0.098), 0 2rpx 36rpx 0 rgba(0,0,0,0.084);
  --md1-shadow-drag: 0 12rpx 20rpx -4rpx rgba(0,0,0,0.20), 0 20rpx 28rpx 2rpx rgba(0,0,0,0.14), 0 6rpx 36rpx 4rpx rgba(0,0,0,0.12);
  --md1-shadow-switch-thumb: 0 2rpx 2rpx 0 rgba(0,0,0,0.20), 0 2rpx 4rpx 0 rgba(0,0,0,0.14), 0 4rpx 2rpx -2rpx rgba(0,0,0,0.12);
  --md1-shadow-switch-thumb-pressed: 0 4rpx 4rpx 0 rgba(0,0,0,0.22), 0 2rpx 8rpx 0 rgba(0,0,0,0.16);
  --md1-control-border: rgba(255,255,255,0.62);
  --md1-control-ripple: #ffffff;
  --md1-switch-track: rgba(255,255,255,0.38);
  --md1-switch-thumb: #fafafa;

  --md1-primary: #038387;
  --md1-primary-dark: #006b6f;
  --md1-on-primary: #ffffff;

  --md1-text-primary: #E6E6E6;
  --md1-text-secondary: #C2C2C2;
  --md1-text-disabled: rgba(255,255,255,0.26);
  --md1-text-hint: #8C8C8C;

  --md1-error: #cf6679;
  --md1-radius-sm: 8rpx;
  --md1-radius-md: 8rpx;
  --md1-radius-lg: 8rpx;
  --md1-radius: 8rpx;

  --color-primary: var(--md1-primary);
  --color-bg: var(--md1-bg);
  --color-bg-card: var(--md1-surface-raised);
  --color-bg-input: var(--md1-field);
  --color-border: var(--md1-divider);
  --color-text: var(--md1-text-primary);
  --color-text-secondary: var(--md1-text-secondary);
  --color-text-muted: var(--md1-text-hint);
  --color-danger: var(--md1-error);
}

.page.large-screen,
.sheet-mask.large-screen,
.dialog-mask.large-screen,
.preview-mask.large-screen,
.drawer-mask.large-screen {
  --md1-radius-sm: 4px;
  --md1-radius-md: 4px;
  --md1-radius-lg: 4px;
  --md1-radius: 4px;
  --md1-shadow-card: 0 3px 1px -2px rgba(0,0,0,0.14), 0 2px 2px 0 rgba(0,0,0,0.098), 0 1px 5px 0 rgba(0,0,0,0.084);
  --md1-shadow-card-tight: 0 3px 1px -2px rgba(0,0,0,0.14), 0 2px 1px 0 rgba(0,0,0,0.098), 0 1px 5px 0 rgba(0,0,0,0.084);
  --md1-shadow-card-up: 0 -3px 1px -2px rgba(0,0,0,0.14), 0 -2px 2px 0 rgba(0,0,0,0.098), 0 -1px 5px 0 rgba(0,0,0,0.084);
  --md1-shadow-appbar: 0 2px 2px -1px rgba(0,0,0,0.18), 0 4px 5px 0 rgba(0,0,0,0.11), 0 1px 7px 0 rgba(0,0,0,0.09);
  --md1-shadow-appbar-up: 0 -2px 2px -1px rgba(0,0,0,0.18), 0 -4px 5px 0 rgba(0,0,0,0.11), 0 -1px 7px 0 rgba(0,0,0,0.09);
  --md1-shadow-bottombar: 0 -2px 2px -1px rgba(0,0,0,0.16), 0 -3px 5px 0 rgba(0,0,0,0.10), 0 -1px 6px 0 rgba(0,0,0,0.08);
  --md1-shadow-fab: 0 3px 5px -1px rgba(0,0,0,0.14), 0 6px 11px 0 rgba(0,0,0,0.098), 0 1px 20px 0 rgba(0,0,0,0.084);
  --md1-shadow-drag: 0 7px 11px -2px rgba(0,0,0,0.20), 0 11px 15px 1px rgba(0,0,0,0.14), 0 3px 20px 2px rgba(0,0,0,0.12);
  --md1-shadow-switch-thumb: 0 1px 1px 0 rgba(0,0,0,0.20), 0 1px 2px 0 rgba(0,0,0,0.14), 0 2px 1px -1px rgba(0,0,0,0.12);
  --md1-shadow-switch-thumb-pressed: 0 2px 2px 0 rgba(0,0,0,0.22), 0 1px 4px 0 rgba(0,0,0,0.16);
}

